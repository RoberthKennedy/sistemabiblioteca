@{
    ViewData["Title"] = "Login";
}

<!-- Link para os ícones do Bootstrap (caso ainda não tenha no seu _Layout.cshtml) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5 pt-4">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            
            <!-- Card de Login -->
            <div class="card shadow border-0 rounded-3 overflow-hidden">
                
                <!-- Cabeçalho com o mesmo Degradê Azul unificado -->
                <div class="card-header text-white text-center py-4 px-3" style="background: linear-gradient(135deg, #0055ff, #0033aa);">
                    <div class="rounded-circle bg-white bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 60px; height: 60px;">
                        <i class="bi bi-shield-lock-fill fs-3"></i>
                    </div>
                    <h3 class="fw-bold mb-0 fs-4">Painel Administrativo</h3>
                </div>

                <!-- Corpo do Formulário -->
                <div class="card-body p-4 bg-white">
                    
                    <!-- Alerta com os dados de acesso de teste -->
                    <div class="alert alert-primary border-0 bg-opacity-10 text-primary small d-flex align-items-center mb-4" style="background-color: rgba(0, 85, 255, 0.08);">
                        <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                        <div>
                            <strong>Acesso de teste:</strong><br>
                            <span class="text-secondary">User:</span> admin@@admin.com<br>
                            <span class="text-secondary">Senha:</span> 123
                        </div>
                    </div>

                    <form asp-action="Login" method="post">
                        
                        <!-- Campo: E-mail -->
                        <div class="form-floating mb-3">
                            <input type="email" name="email" class="form-control border-2 shadow-none" id="floatingInput" placeholder="nome@@exemplo.com" required>
                            <label for="floatingInput" class="text-secondary">
                                <i class="bi bi-envelope-fill text-primary me-1"></i> E-mail
                            </label>
                        </div>
                        
                        <!-- Campo: Senha -->
                        <div class="form-floating mb-4">
                            <input type="password" name="senha" class="form-control border-2 shadow-none" id="floatingPassword" placeholder="Senha" required>
                            <label for="floatingPassword" class="text-secondary">
                                <i class="bi bi-key-fill text-primary me-1"></i> Senha
                            </label>
                        </div>

                        <!-- Feedback de Erro customizado -->
                        @if(ViewBag.Erro != null) 
                        { 
                            <div class="alert alert-danger border-0 small text-center mb-3 py-2">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Erro
                            </div> 
                        }

                        <!-- Botão Entrar -->
                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg fw-bold py-2 shadow-sm" type="submit" style="background-color: #0055ff; border-color: #0055ff;">
                                Entrar <i class="bi bi-box-arrow-in-right ms-1"></i>
                            </button>
                        </div>
                        
                    </form>
                </div>
            </div>

            <!-- Rodapé sutil de retorno -->
            <div class="text-center mt-3">
                <a href="@Url.Action("Index", "Home")" class="text-decoration-none small text-muted hover-primary">
                    <i class="bi bi-arrow-left"></i> Voltar para o início
                </a>
            </div>

        </div>
    </div>
</div>

<style>
    /* Estilo sutil para o foco dos inputs flutuantes combinando com as bordas espessas */
    .form-floating > .form-control:focus {
        border-color: #0055ff !important;
    }
    .hover-primary:hover {
        color: #0055ff !important;
        transition: color 0.2s ease;
    }
</style>