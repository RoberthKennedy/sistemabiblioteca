@model sistemabiblioteca.Models.Produto

@{
    ViewData["Title"] = "Editar Produto";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            
            <div class="card shadow-sm border-0 overflow-hidden">
                
                <div class="card-header text-white text-center py-4 px-4" style="background: linear-gradient(135deg, #0055ff, #0033aa);">
                    <i class="bi bi-pencil-square display-4 mb-2"></i>
                    <h2 class="fw-bold mb-1">Editar Produto</h2>
                    <p class="lead mb-0 opacity-75 small">Altere as informações necessárias e salve as modificações.</p>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Editar" method="post" class="needs-validation" novalidate>
                        
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-4">
                            <label asp-for="Nome" class="form-label fw-semibold text-secondary">
                                <i class="bi bi-tag-fill me-1 text-primary"></i> Nome do Produto
                            </label>
                            <input asp-for="Nome" class="form-control form-control-lg border-2 shadow-none" placeholder="Ex: Livro, Notebook, Cadeira..." required />
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Descricao" class="form-label fw-semibold text-secondary">
                                <i class="bi bi-file-text-fill me-1 text-primary"></i> Descrição Breve
                            </label>
                            <textarea asp-for="Descricao" class="form-control border-2 shadow-none" rows="3" placeholder="Descreva os principais detalhes do produto..." required></textarea>
                            <span asp-validation-for="Descricao" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Preco" class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-cash-coin me-1 text-primary"></i> Preço (R$)
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-2 border-end-0 text-muted fw-bold">R$</span>
                                    <input asp-for="Preco" class="form-control form-control-lg border-2 shadow-none" type="number" step="0.01" placeholder="0,00" required />
                                </div>
                                <span asp-validation-for="Preco" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Categoria" class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-grid-fill me-1 text-primary"></i> Categoria
                                </label>
                                <input asp-for="Categoria" class="form-control form-control-lg border-2 shadow-none" placeholder="Ex: Literatura, Tecnologia..." required />
                                <span asp-validation-for="Categoria" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="text-muted opacity-25 my-4">

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("Index")" class="btn btn-light btn-lg px-4 border text-secondary fw-semibold">
                                <i class="bi bi-arrow-left me-1"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold" style="background-color: #0055ff; border-color: #0055ff;">
                                <i class="bi bi-arrow-clockwise me-1"></i> Atualizar Produto
                            </button>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </div>
</div>