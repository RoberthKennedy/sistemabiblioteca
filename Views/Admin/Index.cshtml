@model List<sistemabiblioteca.Models.Produto>

@{
    ViewData["Title"] = "Acervo de Livros";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-12">
            
            <div class="card shadow-sm border-0 overflow-hidden">
                
                <div class="card-header text-white text-center py-4 px-4" style="background: linear-gradient(135deg, #0055ff, #0033aa);">
                    <i class="bi bi-mortarboard-fill display-4 mb-2"></i>
                    <h1 class="fw-bold mb-1">Biblioteca Universitária</h1>
                    <p class="lead mb-0 opacity-75 small">Gerenciamento inteligente de livros e acervo acadêmico</p>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    
                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
                        <h3 class="fw-bold m-0 text-dark">
                            <i class="bi bi-collection-fill text-primary me-2"></i>Lista de Livros
                        </h3>
                        <a asp-action="Criar" class="btn btn-primary btn-lg fw-bold shadow-sm px-4" style="background-color: #0055ff; border-color: #0055ff;">
                            <i class="bi bi-plus-lg me-1"></i> Novo Livro
                        </a>
                    </div>

                    <form method="get" class="mb-4">
                        <div class="input-group input-group-lg shadow-sm rounded">
                            <span class="input-group-text bg-white border-2 border-end-0 text-muted">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" 
                                   name="busca" 
                                   class="form-control border-2 border-start-0 shadow-none fs-6" 
                                   placeholder="Buscar por título, descrição ou categoria..." />
                            <button type="submit" class="btn btn-dark px-4 fw-bold">
                                Pesquisar
                            </button>
                        </div>
                    </form>

                    <div class="table-responsive rounded border-0 shadow-sm mt-2">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-secondary border-bottom-2">
                                <tr>
                                    <th class="ps-4 py-3 text-uppercase fw-bold small" style="width: 80px;">ID</th>
                                    <th class="py-3 text-uppercase fw-bold small">Livro</th>
                                    <th class="py-3 text-uppercase fw-bold small">Descrição</th>
                                    <th class="py-3 text-uppercase fw-bold small" style="width: 140px;">Preço</th>
                                    <th class="py-3 text-uppercase fw-bold small" style="width: 160px;">Categoria</th>
                                    <th class="pe-4 py-3 text-uppercase fw-bold small text-center" style="width: 180px;">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model == null || !Model.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-5">
                                            <i class="bi bi-inbox text-light-emphasis display-6 mb-2 d-block"></i>
                                            Nenhum livro cadastrado ou encontrado.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-book text-primary fs-4 me-3"></i>
                                                    <span class="fw-bold text-dark fs-6">@item.Nome</span>
                                                </div>
                                            </td>
                                            <td class="text-secondary text-truncate" style="max-width: 250px;">
                                                @item.Descricao
                                            </td>
                                            <td class="fw-semibold text-dark">
                                                R$ @item.Preco.ToString("N2")
                                            </td>
                                            <td>
                                                <span class="badge rounded-pill px-3 py-2 fw-semibold" style="background-color: rgba(0, 85, 255, 0.1); color: #0055ff;">
                                                    <i class="bi bi-bookmark-fill me-1 small"></i>@item.Categoria
                                                </span>
                                            </td>
                                            <td class="pe-4 text-center">
                                                <div class="btn-group gap-2">
                                                    <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm rounded-2 d-inline-flex align-items-center px-3" title="Editar">
                                                        <i class="bi bi-pencil-fill me-1"></i> Editar
                                                    </a>
                                                    <a asp-action="Excluir" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm rounded-2 d-inline-flex align-items-center px-3" title="Excluir">
                                                        <i class="bi bi-trash3-fill me-1"></i> Excluir
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
            
        </div>
    </div>
</div>