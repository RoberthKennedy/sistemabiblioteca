@model List<biblioteca.Models.Cliente>

<div class="container mt-4">
    <h2 class="text-primary mb-4">Registro de Clientes - Biblioteca</h2>

    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Novo Cliente</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Cadastrar" method="post">
                        <div class="mb-3">
                            <label class="form-label">Nome Completo</label>
                            <input type="text" name="Nome" class="form-control" required placeholder="Ex: Ana Souza">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">E-mail</label>
                            <input type="email" name="Email" class="form-control" required placeholder="ana@email.com">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Telefone</label>
                            <input type="tel" name="Telefone" class="form-control" placeholder="(61) 99999-9999">
                        </div>
                        <button type="submit" class="btn btn-success w-100">Cadastrar Cliente</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <h5 class="mb-3">Clientes Ativos</h5>
            <div class="table-responsive">
                <table class="table table-hover border">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted">Nenhum cliente cadastrado ainda.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var cliente in Model)
                            {
                                <tr>
                                    <td>@cliente.Id</td>
                                    <td>@cliente.Nome</td>
                                    <td>@cliente.Email</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>