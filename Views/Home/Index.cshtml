@model List<sistemabiblioteca.Models.Produto>
@{
    ViewData["Title"] = "Gerenciar Produtos";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Painel Administrativo - Produtos</h2>
        <a asp-action="Criar" class="btn btn-success">+ Novo Produto</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-10">
                    <input type="text" name="busca" class="form-control" placeholder="Pesquisar por nome...">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Pesquisar</button>
                </div>
            </form>
        </div>
    </div>

    <table class="table table-hover shadow-sm bg-white rounded">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Categoria</th>
                <th>Preço</th>
                <th class="text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Nome</td>
                    <td><span class="badge bg-info">@p.Categoria</span></td>
                    <td>@p.Preco.ToString("C")</td>
                    <td class="text-center">
                        <a asp-action="Editar" asp-route-id="@p.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Excluir" asp-route-id="@p.Id" class="btn btn-sm btn-danger" onclick="return confirm('Excluir este item?')">Excluir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>