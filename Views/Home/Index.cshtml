@model List<sistemabiblioteca.Models.Livro>
@{
    ViewData["Title"] = "Página Inicial";
    Layout = "_Layout";
}

<!-- Link para os ícones do Bootstrap (caso ainda não tenha no seu _Layout.cshtml) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<!-- Seção Hero Reformulada com o Degradê Padrão -->
<section class="hero text-white">
    <div class="hero-texture"></div>
    <div class="hero-content py-5 px-3">
        <span class="hero-label">
            <i class="bi bi-stars text-info me-1"></i> Biblioteca Digital
        </span>
        <h1 class="hero-title fw-bold">A leitura te leva a lugares onde seus pés nunca chegaram</h1>
        <p class="hero-desc opacity-75">Explore nosso acervo acadêmico e descubra histórias incríveis.</p>
        
        <!-- Formulário de Busca Alinhado ao Padrão -->
        <form asp-action="Index" method="get" class="hero-search mt-4 shadow">
            <div class="input-group">
                <span class="input-group-text bg-white border-0 text-muted ps-3">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="busca" placeholder="Título, autor ou tema..." class="hero-input" />
                <button type="submit" class="hero-btn">
                    Buscar <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </div>
        </form>
    </div>
</section>

<!-- Catálogo de Livros -->
<main class="catalog container my-5">
    
    <div class="catalog-header d-flex align-items-baseline justify-content-between mb-4">
        <h2 class="catalog-title fw-bold m-0">
            <i class="bi bi-collection-fill text-primary me-2"></i>Catálogo
        </h2>
        <span class="catalog-count badge rounded-pill px-3 py-2 fw-semibold" style="background-color: rgba(0, 85, 255, 0.1); color: #0055ff;">
            <i class="bi bi-bookmark-check-fill me-1"></i> @(Model?.Count ?? 0) títulos disponíveis
        </span>
    </div>

    <!-- Grid do Catálogo -->
    <div class="catalog-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var livro in Model)
            {
                <article class="livro rounded-3 overflow-hidden shadow-sm">
                    <!-- Lombada do Livro com o Degradê Azul -->
                    <div class="livro-spine"></div>
                    
                    <div class="livro-body p-4 bg-white">
                        <div class="livro-top d-flex align-items-center justify-content-between mb-2">
                            <span class="livro-tag">
                                <i class="bi bi-book-half me-1"></i> Livro
                            </span>
                        </div>
                        
                        <h3 class="livro-titulo fw-bold text-dark mb-3">@livro.Titulo</h3>
                        
                        <div class="livro-divider"></div>
                        
                        <div class="livro-autor-bloco mt-auto pt-3 d-flex align-items-center gap-1">
                            <span class="livro-autor-label text-muted small fst-italic">por</span>
                            <span class="livro-autor-nome fw-semibold text-secondary">@livro.Autor</span>
                        </div>
                    </div>
                </article>
            }
        }
        else
        {
            <!-- Estado de Lista Vazia -->
            <div class="catalog-empty text-center py-5 w-100 bg-white rounded shadow-sm border border-light">
                <i class="bi bi-journal-x text-light-emphasis display-4 mb-3 d-block"></i>
                <h5 class="fw-bold text-dark">Nenhum livro encontrado</h5>
                <p class="small text-muted mb-0 px-3">Tente buscar por termos genéricos ou verifique a ortografia.</p>
            </div>
        }
    </div>
</main>

<style>
    /* ── Base ── */
    body {
        background: #f4f6f9;
        color: #212529;
        font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
    }

    /* ── Hero Customizado unificado ── */
    .hero {
        position: relative;
        background: linear-gradient(135deg, #0055ff, #0033aa);
        overflow: hidden;
        border-radius: 0 0 24px 24px;
        box-shadow: 0 4px 20px rgba(0, 85, 255, 0.15);
    }

    .hero-texture {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(circle at 15% 85%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 85% 20%, rgba(255, 255, 255, 0.08) 0%, transparent 45%);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
        z-index: 1;
    }

    .hero-label {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #8cb3ff;
        margin-bottom: 16px;
    }

    .hero-title {
        font-size: clamp(1.8rem, 4vw, 3rem);
        line-height: 1.2;
        margin-bottom: 16px;
        letter-spacing: -0.01em;
    }

    /* Barra de Busca Integrada */
    .hero-search {
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        max-width: 560px;
        margin: 0 auto;
    }

    .hero-input {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
        padding: 16px 16px 16px 4px;
        font-size: 1rem;
        color: #212529;
    }
    .hero-input::placeholder { color: #9ca3af; }

    .hero-btn {
        background: #111827;
        color: #ffffff;
        border: none;
        padding: 0 28px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s ease;
        white-space: nowrap;
    }
    .hero-btn:hover { background: #1f2937; }

    /* ── Catálogo ── */
    .catalog-header {
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 16px;
    }

    .catalog-title {
        color: #1e293b;
    }

    .catalog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
    }

    /* ── Card de livro ── */
    .livro {
        display: flex;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s ease;
        cursor: pointer;
        min-height: 180px;
    }

    .livro:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 2rem rgba(0, 85, 255, 0.08) !important;
    }

    .livro-spine {
        width: 10px;
        flex-shrink: 0;
        background: linear-gradient(180deg, #0055ff, #002288); 
    }

    .livro-body {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .livro-tag {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #0055ff;
        background: rgba(0, 85, 255, 0.08);
        padding: 4px 12px;
        border-radius: 999px;
    }

    .livro-titulo {
        font-size: 1.25rem;
        line-height: 1.3;
        letter-spacing: -0.01em;
    }

    .livro-divider {
        height: 1px;
        background: #f1f5f9;
    }

    /* ── Empty ── */
    .catalog-empty {
        grid-column: 1 / -1;
    }
</style>