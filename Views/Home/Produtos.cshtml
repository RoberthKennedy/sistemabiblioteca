@model List<sistemabiblioteca.Models.Produto>
@{
    ViewData["Title"] = "Nossos Produtos";
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-12">
            
            <div class="card shadow-sm border-0 overflow-hidden">
                
                <div class="card-header text-white text-center py-4 px-4" style="background: linear-gradient(135deg, #0055ff, #0033aa);">
                    <i class="bi bi-grid-3x3-gap-fill display-4 mb-2"></i>
                    <h1 class="fw-bold mb-1">Nosso Acervo & Produtos</h1>
                    <p class="lead mb-0 opacity-75 small">Explore nossa coleção de livros, materiais didáticos e recursos acadêmicos.</p>
                </div>

                <div class="card-body p-4 p-md-5 bg-light">
                    
                    <form asp-action="Produtos" method="get" class="mb-5">
                        <div class="input-group input-group-lg shadow-sm rounded bg-white">
                            <span class="input-group-text bg-white border-2 border-end-0 text-muted">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" 
                                   name="busca" 
                                   class="form-control border-2 border-start-0 shadow-none fs-6" 
                                   placeholder="Pesquisar por nome, categoria ou descrição..." />
                            <button type="submit" class="btn btn-primary px-4 fw-bold" style="background-color: #0055ff; border-color: #0055ff;">
                                Pesquisar
                            </button>
                        </div>
                    </form>

                    @if (Model != null && Model.Any())
                    {
                        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                            @foreach (var produto in Model)
                            {
                                <div class="col">
                                    <div class="card h-100 border-0 shadow-sm transition-hover rounded-3">
                                        <div class="card-body p-4 d-flex flex-column">
                                            
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <span class="badge rounded-pill px-3 py-2 fw-semibold" style="background-color: rgba(0, 85, 255, 0.1); color: #0055ff;">
                                                    <i class="bi bi-bookmark-fill me-1 small"></i>@produto.Categoria
                                                </span>
                                                <i class="bi bi-book text-muted opacity-50 fs-5"></i>
                                            </div>

                                            <h5 class="card-title fw-bold text-dark mb-2">@produto.Nome</h5>
                                            
                                            <p class="card-text text-secondary small flex-grow-1 mb-4 text-line-clamp">
                                                @produto.Descricao
                                            </p>
                                            
                                            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-light">
                                                <div class="d-flex flex-column">
                                                    <span class="text-muted small lh-1 mb-1">Valor</span>
                                                    <span class="fw-bold fs-5 text-dark">@produto.Preco.ToString("C")</span>
                                                </div>
                                                <a href="#" class="btn btn-outline-primary fw-semibold btn-sm px-3 rounded-pill" style="border-color: #0055ff; color: #0055ff;">
                                                    Ver Detalhes <i class="bi bi-arrow-right ms-1"></i>
                                                </a>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5 my-4 bg-white rounded shadow-sm border border-light">
                            <i class="bi bi-search-heart text-light-emphasis display-4 mb-3 d-block"></i>
                            <h4 class="fw-bold text-dark">Nenhum resultado encontrado</h4>
                            <p class="small text-secondary px-3">Não encontramos nenhum produto ou livro correspondente aos termos digitados.</p>
                        </div>
                    }

                </div>
            </div>
            
        </div>
    </div>
</div>

<style>
    /* Efeito de Elevação Suave e Transição Duradoura nos Cards */
    .transition-hover {
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s ease;
    }
    .transition-hover:hover {
        transform: translateY(-6px);
        box-shadow: 0 1rem 2rem rgba(0, 85, 255, 0.08) !important;
    }

    /* Limita descrições muito grandes a 3 linhas para manter o alinhamento dos cards */
    .text-line-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
</style>